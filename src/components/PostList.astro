---
import Date from '@components/Date'

export interface Props {
  allPosts: {
    title: string
    location: string
    slug: string
    startDate: string
    endDate: string
  }[]
  postType: string
}

const { allPosts, postType } = Astro.props
---

<ul>
  {
    allPosts.map((post) => (
      <li class="py-5">
        <a
          href={`/works/${post.slug}`}
          class="group -mx-7 -my-5 flex flex-col border-b-2 px-8 py-5 transition-colors hover:bg-back-subtle lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-lg">
            <h3 class="mb-1 text-xl font-bold transition-colors group-hover:text-accent">
              {post.title}{' '}
            </h3>
          </div>
          <div class="max-w-lg">
            <Date dateString={post.startDate} formatStyle="LLLL, yyyy" />-
            {post.endDate === 'Present' && 'Present'}
            {post.endDate !== 'Present' && (
              <Date dateString={post.endDate} formatStyle="LLLL, yyyy" />
            )}
          </div>
        </a>
      </li>
    ))
  }
</ul>
